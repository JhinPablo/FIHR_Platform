APP_NAME=FHIR Platform Corte 2
ENVIRONMENT=development
# FastAPI/SQLAlchemy runtime uses psycopg URLs. Prefer the transaction pooler
# for serverless deploys and short-lived API requests.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Supabase connection variants:
# Direct connection: migrations, admin jobs, long-running DB maintenance.
SUPABASE_DATABASE_URL_DIRECT=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Transaction pooler: recommended for serverless/API runtime.
SUPABASE_DATABASE_URL_POOLER_TRANSACTION=postgresql+psycopg://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:6543/postgres
# Session pooler: clients that require session-level state.
SUPABASE_DATABASE_URL_POOLER_SESSION=postgresql+psycopg://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DATA_ENCRYPTION_KEY=replace-with-fernet-key-from-python-cryptography
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
RATE_LIMIT_PER_MINUTE=120

ACCESS_KEY_ADMIN=dev-access-admin
PERMISSION_KEY_ADMIN=dev-permission-admin
ACCESS_KEY_MEDICO_1=dev-access-medico-1
PERMISSION_KEY_MEDICO_1=dev-permission-medico-1
ACCESS_KEY_MEDICO_2=dev-access-medico-2
PERMISSION_KEY_MEDICO_2=dev-permission-medico-2
ACCESS_KEY_PATIENT=dev-access-patient
PERMISSION_KEY_PATIENT=dev-permission-patient

ML_SERVICE_URL=http://ml-service:8011
DL_SERVICE_URL=http://dl-service:8012
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=clinical-images

# Authorized PhysioNet MIMIC datasets mounted into Docker. Do not commit files.
MIMIC_IV_ROOT=/datasets/mimic-iv
MIMIC_CXR_ROOT=/datasets/mimic-cxr-jpg
SEED_LIMIT_SUBJECTS=30
SEED_MAX_IMAGES=30
SEED_MAX_LABS_PER_SUBJECT=8
